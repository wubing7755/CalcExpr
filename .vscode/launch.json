{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Calculator (No Debug)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/bin/calculator",
      "args": [],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "preLaunchTask": "CMake Build"
    },
    {
      "name": "Calculator (Full Trace)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/bin/calculator",
      "args": ["--debug", "--debug-level=5"],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "preLaunchTask": "CMake Clean and Build (Debug)"
    },
    {
      "name": "Calculator (Show Steps)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/bin/calculator",
      "args": ["--debug", "--debug-level=4"],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "preLaunchTask": "CMake Clean and Build (Debug)"
    },
    {
      "name": "Calculator (Parser Detail)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/bin/calculator",
      "args": ["--debug", "--debug-module=parser", "--debug-level=5"],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "preLaunchTask": "CMake Clean and Build (Debug)"
    },
    {
      "name": "Calculator (Lexer Detail)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/bin/calculator",
      "args": ["--debug", "--debug-module=lexer", "--debug-level=4"],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "preLaunchTask": "CMake Clean and Build (Debug)"
    }
  ]
}
